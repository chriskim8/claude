# Claude Code Credentials Setup
#
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to GitHub (it's in .gitignore)
#
# For Claude Code (web UI):
# 1. Set these as environment variables in Claude Code settings
# 2. Or create a local .env file (Code can read it if running locally)

# ============================================
# CANNY API
# ============================================
CANNY_API_KEY=your_canny_api_key_here

# ============================================
# GOOGLE SERVICES
# ============================================
GOOGLE_CLIENT_SECRET_PATH=~/google-services/credentials/client_secret.json
GOOGLE_TOKEN_PATH=~/google-services/credentials/token.json

# ============================================
# ZENDESK API
# ============================================
ZENDESK_SUBDOMAIN=your_zendesk_subdomain
ZENDESK_EMAIL=your_zendesk_email@example.com
ZENDESK_API_TOKEN=your_zendesk_api_token

# ============================================
# AMION CREDENTIALS
# ============================================
AMION_USERNAME=your_amion_username
AMION_PASSWORD=your_amion_password
JIRA_EMAIL=your_jira_email@example.com
JIRA_TOKEN=your_jira_api_token
JIRA_BASE_URL=https://your-instance.atlassian.net

# ============================================
# ANTHROPIC API
# ============================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
